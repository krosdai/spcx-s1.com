{
  "packageManager": "pnpm@11.15.1+sha512.81350b07e53c9538a02f1f2303b4290fa2d7be04e56e2a970c4cc4b417dc761de196edabd49d55c7dc9580db81007c44143e4e3d7e462b3000d23c255122d065",
  "engines": {
    "node": ">=22.22.1"
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --filter web dev",
    "format": "prettier --write --ignore-unknown --log-level=warn . && autocorrect --fix .",
    "lint": "eslint . --no-error-on-unmatched-pattern && pnpm run --filter '*' lint && prettier --check --ignore-unknown .",
    "lint:staged": "lint-staged",
    "lint:fix": "eslint . --no-error-on-unmatched-pattern --fix && pnpm run --filter '*' lint:fix && pnpm run format",
    "prepare": "husky",
    "test": "pnpm -r test",
    "validate": "pnpm --filter @spcx/content validate"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "autocorrect-node": "^2.14.0",
    "eslint": "^10.4.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "prettier": "^3.8.3",
    "typescript-eslint": "^8.59.4"
  }
}
